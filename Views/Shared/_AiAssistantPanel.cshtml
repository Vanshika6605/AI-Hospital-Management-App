<style>
    /* Glassmorphism AI Assistant Panel */
    #ai-assistant-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    #ai-assistant-btn {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
        color: white;
        border: none;
        box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        transition: transform 0.3s ease;
    }

    #ai-assistant-btn:hover {
        transform: scale(1.05);
    }

    #ai-panel {
        display: none;
        position: absolute;
        bottom: 80px;
        right: 0;
        width: 380px;
        height: 550px;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        opacity: 0;
        pointer-events: none;
        transform: translateY(20px);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    #ai-panel.open {
        opacity: 1;
        pointer-events: all;
        transform: translateY(0);
    }

    .ai-header {
        background: rgba(255, 255, 255, 0.9);
        padding: 15px 20px;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .ai-title {
        font-weight: 600;
        color: #1a1f36;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .ai-title i {
        color: #0d6efd;
    }

    .ai-close-btn {
        background: none;
        border: none;
        color: #6c757d;
        cursor: pointer;
        font-size: 18px;
    }

    .ai-chat-body {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .ai-msg {
        max-width: 85%;
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 0.9rem;
        line-height: 1.4;
        animation: fadeIn 0.3s ease;
    }

    .ai-msg.user {
        background: #0d6efd;
        color: white;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
    }

    .ai-msg.assistant {
        background: rgba(243, 244, 246, 0.9);
        color: #1a1f36;
        align-self: flex-start;
        border-bottom-left-radius: 4px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

    .ai-msg.assistant pre {
        background: #2d3748;
        color: #f7fafc;
        padding: 8px;
        border-radius: 6px;
        overflow-x: auto;
    }

    .ai-msg.assistant code {
        font-family: monospace;
    }

    .ai-citation-badge {
        font-size: 0.7rem;
        background: #e2e8f0;
        color: #4a5568;
        padding: 2px 6px;
        border-radius: 10px;
        margin-left: 4px;
        vertical-align: super;
        cursor: help;
    }
    
    .ai-confidence {
        font-size: 0.75rem;
        margin-top: 6px;
        text-align: right;
        display: block;
    }
    
    .confidence-high { color: #10b981; }
    .confidence-med { color: #f59e0b; }
    .confidence-low { color: #ef4444; }

    .ai-input-area {
        padding: 15px;
        background: rgba(255, 255, 255, 0.9);
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .ai-input-wrapper {
        display: flex;
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 24px;
        padding: 4px 8px;
        align-items: center;
    }

    #ai-input {
        flex: 1;
        border: none;
        background: transparent;
        padding: 8px 12px;
        font-size: 0.9rem;
        outline: none;
    }

    #ai-send-btn {
        background: #0d6efd;
        color: white;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
    }

    #ai-send-btn:hover {
        background: #0b5ed7;
    }

    #ai-send-btn:disabled {
        background: #a5c8ff;
        cursor: not-allowed;
    }

    .ai-typing {
        display: flex;
        gap: 4px;
        padding: 6px 4px;
    }

    .ai-typing span {
        width: 6px;
        height: 6px;
        background: #adb5bd;
        border-radius: 50%;
        animation: typing 1.4s infinite ease-in-out both;
    }

    .ai-typing span:nth-child(1) { animation-delay: -0.32s; }
    .ai-typing span:nth-child(2) { animation-delay: -0.16s; }

    @@keyframes typing {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1); }
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div id="ai-assistant-container">
    <div id="ai-panel">
        <div class="ai-header">
            <h6 class="ai-title"><i class="fas fa-sparkles"></i> MediAI Assistant</h6>
            <button class="ai-close-btn" id="ai-close-btn"><i class="fas fa-times"></i></button>
        </div>
        <div class="ai-chat-body" id="ai-chat-body">
            <div class="ai-msg assistant">
                Hello! I am MediAI, your operational assistant. I can help you with hospital guidelines, billing details, admissions, and more based on your role. How can I assist you today?
            </div>
        </div>
        <div class="ai-input-area">
            <div class="ai-input-wrapper">
                <input type="text" id="ai-input" placeholder="Ask a question..." autocomplete="off" />
                <button id="ai-send-btn"><i class="fas fa-paper-plane"></i></button>
            </div>
        </div>
    </div>
    <button id="ai-assistant-btn">
        <i class="fas fa-robot"></i>
    </button>
</div>
