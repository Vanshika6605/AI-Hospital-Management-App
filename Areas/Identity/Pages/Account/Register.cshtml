@page
@model AIHospitalManagementSys.Areas.Identity.Pages.Account.RegisterModel
@{ Layout = null; }
<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>MediAI - Secure Registration</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-secondary": "#ffffff",
                      "surface-bright": "#f7f9fb",
                      "inverse-on-surface": "#eff1f3",
                      "on-tertiary-fixed": "#23005c",
                      "on-tertiary-container": "#3e0097",
                      "on-primary": "#ffffff",
                      "outline-variant": "#bec8d2",
                      "secondary-container": "#6df5e1",
                      "on-error-container": "#93000a",
                      "surface-container-low": "#f2f4f6",
                      "on-background": "#191c1e",
                      "error": "#ba1a1a",
                      "tertiary-fixed": "#e9ddff",
                      "tertiary-fixed-dim": "#d0bcff",
                      "primary-container": "#0ea5e9",
                      "on-secondary-fixed-variant": "#005048",
                      "surface-variant": "#e0e3e5",
                      "surface": "#f7f9fb",
                      "primary": "#006591",
                      "on-tertiary-fixed-variant": "#5516be",
                      "primary-fixed": "#c9e6ff",
                      "error-container": "#ffdad6",
                      "surface-container-highest": "#e0e3e5",
                      "on-primary-container": "#003751",
                      "on-primary-fixed-variant": "#004c6e",
                      "surface-tint": "#006591",
                      "on-error": "#ffffff",
                      "on-secondary-container": "#006f64",
                      "surface-container-high": "#e6e8ea",
                      "surface-dim": "#d8dadc",
                      "surface-container-lowest": "#ffffff",
                      "tertiary-container": "#a986ff",
                      "inverse-primary": "#89ceff",
                      "on-surface-variant": "#3e4850",
                      "on-tertiary": "#ffffff",
                      "primary-fixed-dim": "#89ceff",
                      "secondary-fixed-dim": "#4fdbc8",
                      "on-secondary-fixed": "#00201c",
                      "secondary": "#006b5f",
                      "surface-container": "#eceef0",
                      "background": "#f7f9fb",
                      "tertiary": "#6d3bd7",
                      "secondary-fixed": "#71f8e4",
                      "outline": "#6e7881",
                      "inverse-surface": "#2d3133",
                      "on-primary-fixed": "#001e2f",
                      "on-surface": "#191c1e"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px",
                      "2xl": "1rem",
                      "3xl": "1.5rem"
              },
              "fontFamily": {
                      "label-md": ["Inter"],
                      "label-sm": ["Inter"],
                      "body-lg": ["Inter"],
                      "headline-md": ["Inter"],
                      "body-md": ["Inter"],
                      "headline-lg-mobile": ["Inter"],
                      "display-lg": ["Inter"],
                      "headline-lg": ["Inter"]
              }
      },
          },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .material-symbols-outlined[data-weight="fill"] {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-surface-bright min-h-screen flex items-center justify-center relative overflow-y-auto font-body-md text-on-surface">
<!-- Ambient Background -->
<div class="absolute inset-0 z-0">
<img alt="Clinical Background" class="w-full h-full object-cover opacity-40 mix-blend-luminosity" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAiBgFw9-ryAeEf3pLd9LZbOH_rJbJNfndjBJTYbQtIoAhAfpZKTSTUQH3gHsLACKkwcux03RaizBDekeFk0GCSA_kg2NrP4KI-BQ_YmWiEfyQbyi6y7c9XnrUv8b5nxvH7m7aIEwVjFtJAZtf0wfhqm-sezYOK3Dl7TM8_ka0YXgGLcE-PxfIiGkjuFZPIy0fnU_pZrQuCXce0mJLT4DW45aJRyv6sfwjpVIVG5a1IxQsi2rU_nDz3rbTzPAmeDsPrOsbfmy-xTQs"/>
<div class="absolute inset-0 bg-surface/70 backdrop-blur-[60px]"></div>
<div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-primary/10 blur-[100px]"></div>
<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-secondary/10 blur-[100px]"></div>
</div>

<!-- Main Register Container -->
<main class="relative z-10 w-full max-w-[500px] px-6 py-8 flex flex-col my-10">
<!-- Glassmorphic Card -->
<div class="bg-surface-container-lowest/80 backdrop-blur-2xl border border-white/60 shadow-[0_16px_40px_rgba(0,101,145,0.08)] rounded-3xl p-8 md:p-10 flex flex-col gap-8 relative overflow-hidden">
<!-- Subtle internal glow -->
<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary opacity-50"></div>

<!-- Header -->
<div class="text-center flex flex-col gap-2 items-center">
<div class="w-12 h-12 rounded-2xl bg-primary-container/20 flex items-center justify-center mb-2 shadow-[inset_0_2px_10px_rgba(255,255,255,0.5)] border border-primary/10">
<span class="material-symbols-outlined text-primary text-[28px]" data-icon="person_add" data-weight="fill">person_add</span>
</div>
<h1 class="font-headline-lg text-headline-lg bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary">Join MediAI</h1>
<p class="font-body-md text-body-md text-on-surface-variant">Create your secure patient portal account</p>
</div>

<!-- Register Form -->
<form id="registerForm" method="post" class="flex flex-col gap-6">
    <div asp-validation-summary="ModelOnly" class="text-error font-label-sm" role="alert"></div>

    <!-- Full Name Input -->
    <div class="flex flex-col gap-2 relative">
        <label asp-for="Input.FullName" class="font-label-sm text-label-sm text-on-surface px-1">Full Name</label>
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <span class="material-symbols-outlined text-outline text-[20px]" data-icon="person">person</span>
            </div>
            <input asp-for="Input.FullName" class="w-full pl-11 pr-4 py-3 rounded-xl bg-surface-container-low/50 border border-outline-variant/40 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary shadow-[inset_0_2px_4px_rgba(0,0,0,0.02)] transition-all" autocomplete="name" aria-required="true" placeholder="John Doe" />
        </div>
        <span asp-validation-for="Input.FullName" class="text-error font-label-sm px-1"></span>
    </div>

    <!-- Email Input -->
    <div class="flex flex-col gap-2 relative">
        <label asp-for="Input.Email" class="font-label-sm text-label-sm text-on-surface px-1">Email Address</label>
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <span class="material-symbols-outlined text-outline text-[20px]" data-icon="mail">mail</span>
            </div>
            <input asp-for="Input.Email" class="w-full pl-11 pr-4 py-3 rounded-xl bg-surface-container-low/50 border border-outline-variant/40 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary shadow-[inset_0_2px_4px_rgba(0,0,0,0.02)] transition-all" autocomplete="username" aria-required="true" placeholder="john@example.com" />
        </div>
        <span asp-validation-for="Input.Email" class="text-error font-label-sm px-1"></span>
    </div>

    <!-- Password Input -->
    <div class="flex flex-col gap-2 relative">
        <label asp-for="Input.Password" class="font-label-sm text-label-sm text-on-surface px-1">Password</label>
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <span class="material-symbols-outlined text-outline text-[20px]" data-icon="lock">lock</span>
            </div>
            <input asp-for="Input.Password" class="w-full pl-11 pr-4 py-3 rounded-xl bg-surface-container-low/50 border border-outline-variant/40 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary shadow-[inset_0_2px_4px_rgba(0,0,0,0.02)] transition-all" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
        </div>
        <span asp-validation-for="Input.Password" class="text-error font-label-sm px-1"></span>
    </div>

    <!-- Confirm Password Input -->
    <div class="flex flex-col gap-2 relative">
        <label asp-for="Input.ConfirmPassword" class="font-label-sm text-label-sm text-on-surface px-1">Confirm Password</label>
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <span class="material-symbols-outlined text-outline text-[20px]" data-icon="lock_reset">lock_reset</span>
            </div>
            <input asp-for="Input.ConfirmPassword" class="w-full pl-11 pr-4 py-3 rounded-xl bg-surface-container-low/50 border border-outline-variant/40 text-on-surface focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary shadow-[inset_0_2px_4px_rgba(0,0,0,0.02)] transition-all" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
        </div>
        <span asp-validation-for="Input.ConfirmPassword" class="text-error font-label-sm px-1"></span>
    </div>

    <!-- Submit Button -->
    <button id="registerSubmit" type="submit" class="w-full mt-2 py-3.5 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-label-md text-label-md shadow-[0_4px_14px_rgba(0,101,145,0.25)] hover:shadow-[0_6px_20px_rgba(0,101,145,0.35)] hover:-translate-y-0.5 transition-all flex justify-center items-center gap-2 relative overflow-hidden group">
        <div class="absolute inset-0 bg-white/20 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 ease-in-out"></div>
        <span class="relative z-10">Create Account</span>
        <span class="material-symbols-outlined text-[18px] relative z-10" data-icon="arrow_forward">arrow_forward</span>
    </button>
</form>

<div class="text-center pt-2 border-t border-outline-variant/20">
    <p class="font-label-sm text-label-sm text-on-surface-variant">
        Already have an account? <a asp-page="./Login" class="text-primary font-bold hover:underline">Log in here</a>
    </p>
</div>

</div>
<!-- System Status -->
<div class="mt-8 text-center flex items-center justify-center gap-2 font-label-sm text-label-sm text-on-surface-variant">
<span class="w-2 h-2 rounded-full bg-secondary shadow-[0_0_8px_rgba(0,107,95,0.6)] animate-pulse"></span>
            MediAI Core System: Online
        </div>
</main>
</body></html>
