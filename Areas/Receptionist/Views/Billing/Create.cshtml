@model AIHospitalManagementSys.ViewModels.BillViewModel

@{
    ViewData["Title"] = "Generate Bill";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Generate Bill for @Model.PatientName</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <input type="hidden" asp-for="AppointmentId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Doctor</label>
                            <input class="form-control" value="@Model.DoctorName" readonly />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Appointment Date</label>
                            <input class="form-control" value="@Model.AppointmentDate.ToString("MMM dd, yyyy hh:mm tt")" readonly />
                        </div>

                        <hr />

                        <div class="mb-3">
                            <label asp-for="ConsultationCharges" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="ConsultationCharges" class="form-control bill-input" type="number" step="0.01" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MedicineCharges" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="MedicineCharges" class="form-control bill-input" type="number" step="0.01" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LabCharges" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="LabCharges" class="form-control bill-input" type="number" step="0.01" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ServiceCharges" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="ServiceCharges" class="form-control bill-input" type="number" step="0.01" />
                            </div>
                        </div>

                        <div class="card bg-light mt-4">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">Total Amount</h5>
                                    <h4 class="mb-0 text-primary" id="totalDisplay">$0.00</h4>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">Generate Bill</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            function calculateTotal() {
                var total = 0;
                $('.bill-input').each(function() {
                    var val = parseFloat($(this).val()) || 0;
                    total += val;
                });
                $('#totalDisplay').text('$' + total.toFixed(2));
            }

            $('.bill-input').on('input', calculateTotal);
            calculateTotal(); // Initial call
        });
    </script>
}
