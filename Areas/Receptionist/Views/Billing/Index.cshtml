@model IEnumerable<AIHospitalManagementSys.ViewModels.BillViewModel>

@{
    ViewData["Title"] = "Billing Records";
}

<div class="max-w-7xl mx-auto flex flex-col gap-section-gap pt-8 md:pt-0 pb-12">
    <!-- Header Section -->
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-stack-md">
        <div>
            <p class="font-label-md text-label-md text-on-surface-variant mb-1">Financial Operations</p>
            <h2 class="font-display-lg text-display-lg text-on-surface">Billing & <span class="gradient-text">Invoices</span></h2>
        </div>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="bg-status-completed-bg text-status-completed-text p-4 rounded-xl font-label-md flex items-center justify-between border border-status-completed-text/20">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined">check_circle</span>
                @TempData["Success"]
            </div>
            <button onclick="this.parentElement.style.display='none'" class="hover:opacity-70"><span class="material-symbols-outlined">close</span></button>
        </div>
    }

    <div class="glass-panel flex flex-col overflow-hidden shadow-md">
        <div class="p-6 border-b border-outline-variant/30 flex justify-between items-center bg-surface-container/30">
            <h3 class="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">receipt_long</span>
                All Records
            </h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container/50 border-b border-outline-variant/30 text-on-surface-variant font-label-sm uppercase tracking-wider">
                        <th class="p-4 font-bold">Bill #</th>
                        <th class="p-4 font-bold">Patient</th>
                        <th class="p-4 font-bold">Doctor</th>
                        <th class="p-4 font-bold">Amount</th>
                        <th class="p-4 font-bold">Status</th>
                        <th class="p-4 font-bold text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-b border-outline-variant/10 hover:bg-surface-container-lowest/50 transition-colors">
                            <td class="p-4 font-mono font-bold text-on-surface-variant">#@item.Id</td>
                            <td class="p-4 font-label-md font-bold text-on-surface">@item.PatientName</td>
                            <td class="p-4 font-label-md text-on-surface">Dr. @item.DoctorName</td>
                            <td class="p-4 font-bold text-on-surface">@item.TotalAmount.ToString("C")</td>
                            <td class="p-4">
                                @if (item.PaymentStatus == "Paid")
                                {
                                    <span class="px-3 py-1 rounded-full text-xs font-bold badge-completed flex items-center gap-1 w-max">
                                        <span class="w-2 h-2 rounded-full bg-status-completed-text"></span> Paid
                                    </span>
                                }
                                else if (item.PaymentStatus == "Draft")
                                {
                                    <span class="px-3 py-1 rounded-full text-xs font-bold bg-error/10 text-error flex items-center gap-1 w-max">
                                        <span class="w-2 h-2 rounded-full bg-error"></span> Draft
                                    </span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 rounded-full text-xs font-bold badge-pending flex items-center gap-1 w-max">
                                        <span class="w-2 h-2 rounded-full bg-status-pending-text"></span> Pending
                                    </span>
                                }
                            </td>
                            <td class="p-4 text-center flex justify-center gap-2">
                                @if (item.PaymentStatus == "Draft")
                                {
                                    <form asp-action="MarkPending" asp-route-id="@item.Id" method="post" class="inline">
                                        <button type="submit" class="text-error hover:text-white bg-error/10 hover:bg-error px-3 py-1.5 rounded-lg text-sm font-bold transition-colors flex items-center gap-1 shadow-sm">
                                            <span class="material-symbols-outlined text-[16px]">task_alt</span> Finalize
                                        </button>
                                    </form>
                                }
                                <a asp-action="Invoice" asp-route-id="@item.Id" class="text-primary hover:text-white bg-primary/10 hover:bg-primary px-3 py-1.5 rounded-lg text-sm font-bold transition-colors flex items-center gap-1 shadow-sm">
                                    <span class="material-symbols-outlined text-[16px]">visibility</span> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}
