@using Microsoft.AspNetCore.Identity
@using AIHospitalManagementSys.Models.Domain
@using AIHospitalManagementSys.Services.Interfaces
@inject UserManager<ApplicationUser> UserManager
@inject IPatientService PatientService
@{
    var user = await UserManager.GetUserAsync(User);
    var patients = await PatientService.GetAllPatientsAsync();
    var currentPatient = patients.FirstOrDefault(p => p.ApplicationUserId == user?.Id);
    var fullName = currentPatient?.FullName ?? user?.FullName ?? "Patient";
    var patientId = currentPatient?.Id ?? 0;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>MediAI - @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "on-secondary": "#ffffff", "surface-bright": "#f7f9fb", "inverse-on-surface": "#eff1f3",
                      "on-tertiary-fixed": "#23005c", "on-tertiary-container": "#3e0097", "on-primary": "#ffffff",
                      "outline-variant": "#bec8d2", "secondary-container": "#6df5e1", "on-error-container": "#93000a",
                      "surface-container-low": "#f2f4f6", "on-background": "#191c1e", "error": "#ba1a1a",
                      "tertiary-fixed": "#e9ddff", "tertiary-fixed-dim": "#d0bcff", "primary-container": "#0ea5e9",
                      "on-secondary-fixed-variant": "#005048", "surface-variant": "#e0e3e5", "surface": "#f7f9fb",
                      "primary": "#006591", "on-tertiary-fixed-variant": "#5516be", "primary-fixed": "#c9e6ff",
                      "error-container": "#ffdad6", "surface-container-highest": "#e0e3e5",
                      "on-primary-container": "#003751", "on-primary-fixed-variant": "#004c6e",
                      "surface-tint": "#006591", "on-error": "#ffffff", "on-secondary-container": "#006f64",
                      "surface-container-high": "#e6e8ea", "surface-dim": "#d8dadc", "surface-container-lowest": "#ffffff",
                      "tertiary-container": "#a986ff", "inverse-primary": "#89ceff", "on-surface-variant": "#3e4850",
                      "on-tertiary": "#ffffff", "primary-fixed-dim": "#89ceff", "secondary-fixed-dim": "#4fdbc8",
                      "on-secondary-fixed": "#00201c", "secondary": "#006b5f", "surface-container": "#eceef0",
                      "background": "#f7f9fb", "tertiary": "#6d3bd7", "secondary-fixed": "#71f8e4",
                      "outline": "#6e7881", "inverse-surface": "#2d3133", "on-primary-fixed": "#001e2f",
                      "on-surface": "#191c1e"
              },
              "fontFamily": {
                      "label-md": ["Inter"], "label-sm": ["Inter"], "body-lg": ["Inter"],
                      "headline-md": ["Inter"], "body-md": ["Inter"], "headline-lg-mobile": ["Inter"],
                      "display-lg": ["Inter"], "headline-lg": ["Inter"]
              },
              "spacing": { "section-gap": "32px", "stack-sm": "8px", "container-margin": "24px", "gutter": "16px", "stack-md": "16px", "unit": "4px" },
              "borderRadius": { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
              "fontSize": {
                      "label-md": ["14px", {"lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "500"}],
                      "label-sm": ["12px", {"lineHeight": "16px", "letterSpacing": "0.02em", "fontWeight": "600"}],
                      "body-lg": ["18px", {"lineHeight": "28px", "letterSpacing": "0em", "fontWeight": "400"}],
                      "headline-md": ["24px", {"lineHeight": "32px", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                      "body-md": ["16px", {"lineHeight": "24px", "letterSpacing": "0em", "fontWeight": "400"}],
                      "headline-lg-mobile": ["24px", {"lineHeight": "32px", "letterSpacing": "-0.01em", "fontWeight": "700"}],
                      "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                      "headline-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "700"}]
              }
            }
          }
        }
    </script>
    <style type="text/tailwindcss">
        @@layer utilities {
            .glass-panel { @@apply bg-surface-container-lowest/80 backdrop-blur-[20px] border border-white/40 shadow-sm rounded-xl; }
            .glass-glow { @@apply shadow-[0_0_40px_rgba(0,101,145,0.05)]; }
            .ai-glow { @@apply relative; }
            .ai-glow::after { content: ''; @@apply absolute -inset-1 bg-gradient-to-r from-primary to-secondary rounded-[inherit] blur opacity-20 -z-10; }
        }
        #toast-container { z-index: 999999 !important; }
    </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen flex antialiased">
    <!-- SideNavBar -->
    <aside class="fixed left-0 top-0 h-screen w-[280px] bg-surface-container-lowest/60 backdrop-blur-2xl dark:bg-surface-container/40 border-r border-white/20 shadow-[0_0_40px_rgba(0,101,145,0.05)] z-40 hidden md:flex flex-col p-container-margin gap-section-gap">
        <div class="flex items-center gap-stack-sm mb-section-gap">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1; font-size: 32px;">health_and_safety</span>
            <span class="font-headline-lg-mobile text-headline-lg-mobile font-black text-primary">MediAI</span>
        </div>
        
        <div class="flex items-center gap-stack-md mb-stack-md p-3 rounded-xl bg-surface-container/50">
            <img alt="Patient Profile" class="w-12 h-12 rounded-full border-2 border-white/50" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBmor2NjTE0FtdQiCLgBJ3J5Ms9GuP_fAW7tbc-VVbEfqMqP6cXGQCAFkXUrQ-yB1RIkpn9kVv2Lnnrx3pq4pzTKTm8rkRnZU-dyCclD0nFTTwuTw6TmELr0Lp6_koNkCPxfe5Nn7FIvvhmJUA5su5fuBVVfoc_Eew6GmXmHfBk1Mc0MSMh_GpDeR3fnyOXmvCM3l-AhJ1ot4F4QJIJNnqkEEh5_MgXxV2NiqZtaCCVgoNw-mRd6ZIMkQUnfgaNAMksM8K5CKgPNCY"/>
            <div>
                <p class="font-label-md text-label-md font-bold text-on-surface">@fullName</p>
                <p class="font-label-sm text-label-sm text-on-surface-variant">Patient ID: M-@patientId.ToString("D4")</p>
            </div>
        </div>
        
        <nav class="flex-1 flex flex-col gap-unit">
            <a class="flex items-center gap-stack-md p-3 rounded-xl transition-all duration-200 active:scale-[0.98] @(currentAction == "Index" ? "bg-secondary-container/30 text-on-secondary-container border-l-4 border-tertiary shadow-[inset_0_1px_2px_rgba(255,255,255,0.3)]" : "text-on-surface-variant hover:bg-surface-container-high/40 hover:translate-x-1")" asp-area="Patient" asp-controller="Dashboard" asp-action="Index">
                <span class="material-symbols-outlined" style="@(currentAction == "Index" ? "font-variation-settings: 'FILL' 1;" : "")">dashboard</span>
                <span class="font-label-md text-label-md @(currentAction == "Index" ? "font-bold" : "")">Dashboard</span>
            </a>
            <a class="flex items-center gap-stack-md p-3 rounded-xl transition-all duration-200 active:scale-[0.98] @(currentAction == "Profile" ? "bg-secondary-container/30 text-on-secondary-container border-l-4 border-tertiary shadow-[inset_0_1px_2px_rgba(255,255,255,0.3)]" : "text-on-surface-variant hover:bg-surface-container-high/40 hover:translate-x-1")" asp-area="Patient" asp-controller="Dashboard" asp-action="Profile">
                <span class="material-symbols-outlined" style="@(currentAction == "Profile" ? "font-variation-settings: 'FILL' 1;" : "")">person</span>
                <span class="font-label-md text-label-md @(currentAction == "Profile" ? "font-bold" : "")">Profile</span>
            </a>
            <a class="flex items-center gap-stack-md p-3 rounded-xl transition-all duration-200 active:scale-[0.98] @(currentAction == "AIInsights" ? "bg-secondary-container/30 text-on-secondary-container border-l-4 border-tertiary shadow-[inset_0_1px_2px_rgba(255,255,255,0.3)]" : "text-on-surface-variant hover:bg-surface-container-high/40 hover:translate-x-1")" asp-area="Patient" asp-controller="Dashboard" asp-action="AIInsights">
                <span class="material-symbols-outlined" style="@(currentAction == "AIInsights" ? "font-variation-settings: 'FILL' 1;" : "")">psychology</span>
                <span class="font-label-md text-label-md @(currentAction == "AIInsights" ? "font-bold" : "")">AI Insights</span>
            </a>
            <a class="flex items-center gap-stack-md p-3 rounded-xl transition-all duration-200 active:scale-[0.98] @(currentAction == "Analytics" ? "bg-secondary-container/30 text-on-secondary-container border-l-4 border-tertiary shadow-[inset_0_1px_2px_rgba(255,255,255,0.3)]" : "text-on-surface-variant hover:bg-surface-container-high/40 hover:translate-x-1")" asp-area="Patient" asp-controller="Dashboard" asp-action="Analytics">
                <span class="material-symbols-outlined" style="@(currentAction == "Analytics" ? "font-variation-settings: 'FILL' 1;" : "")">monitoring</span>
                <span class="font-label-md text-label-md @(currentAction == "Analytics" ? "font-bold" : "")">Analytics</span>
            </a>
            <a class="flex items-center gap-stack-md p-3 rounded-xl transition-all duration-200 active:scale-[0.98] @(currentAction == "Schedules" ? "bg-secondary-container/30 text-on-secondary-container border-l-4 border-tertiary shadow-[inset_0_1px_2px_rgba(255,255,255,0.3)]" : "text-on-surface-variant hover:bg-surface-container-high/40 hover:translate-x-1")" asp-area="Patient" asp-controller="Dashboard" asp-action="Schedules">
                <span class="material-symbols-outlined" style="@(currentAction == "Schedules" ? "font-variation-settings: 'FILL' 1;" : "")">calendar_month</span>
                <span class="font-label-md text-label-md @(currentAction == "Schedules" ? "font-bold" : "")">Schedules</span>
            </a>
            <a class="flex items-center gap-stack-md p-3 rounded-xl transition-all duration-200 active:scale-[0.98] @(currentAction == "Emergency" ? "bg-secondary-container/30 text-on-secondary-container border-l-4 border-tertiary shadow-[inset_0_1px_2px_rgba(255,255,255,0.3)]" : "text-on-surface-variant hover:bg-surface-container-high/40 hover:translate-x-1")" asp-area="Patient" asp-controller="Dashboard" asp-action="Emergency">
                <span class="material-symbols-outlined text-error" style="@(currentAction == "Emergency" ? "font-variation-settings: 'FILL' 1;" : "")">emergency</span>
                <span class="font-label-md text-label-md text-error @(currentAction == "Emergency" ? "font-bold" : "")">Emergency</span>
            </a>
        </nav>
        
        <button class="w-full py-3 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-label-md text-label-md font-bold shadow-md hover:shadow-lg transition-all ai-glow active:scale-[0.98]" onclick="showComingSoon('AI Consultant')">
            AI Consultant
        </button>
        
        <div class="mt-auto pt-section-gap border-t border-outline-variant/30 flex flex-col gap-unit">
            <a class="flex items-center gap-stack-md p-3 rounded-xl transition-all duration-200 active:scale-[0.98] @(currentAction == "Settings" ? "bg-secondary-container/30 text-on-secondary-container border-l-4 border-tertiary shadow-[inset_0_1px_2px_rgba(255,255,255,0.3)]" : "text-on-surface-variant hover:bg-surface-container-high/40 hover:translate-x-1")" asp-area="Patient" asp-controller="Dashboard" asp-action="Settings">
                <span class="material-symbols-outlined" style="@(currentAction == "Settings" ? "font-variation-settings: 'FILL' 1;" : "")">settings</span>
                <span class="font-label-md text-label-md @(currentAction == "Settings" ? "font-bold" : "")">Settings</span>
            </a>
            <form class="form-inline m-0 p-0 w-full" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="flex items-center gap-stack-md text-on-surface-variant p-3 hover:bg-surface-container-high/40 rounded-xl transition-all hover:translate-x-1 duration-200 active:scale-[0.98] w-full border-0 bg-transparent text-left cursor-pointer">
                    <span class="material-symbols-outlined">logout</span>
                    <span class="font-label-md text-label-md">Logout</span>
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Content Canvas -->
    <main class="flex-1 md:ml-[280px] p-container-margin lg:p-[48px] max-w-[1440px] mx-auto w-full">
        <!-- Header area for Mobile (hidden on desktop) -->
        <header class="md:hidden flex justify-between items-center mb-section-gap bg-surface-container-lowest/80 backdrop-blur-xl p-4 rounded-2xl shadow-sm border border-white/40">
            <span class="font-headline-lg-mobile text-headline-lg-mobile font-black text-primary">MediAI</span>
            <button class="p-2 rounded-full bg-surface-container hover:bg-surface-container-high transition-colors">
                <span class="material-symbols-outlined text-on-surface">menu</span>
            </button>
        </header>

        @RenderBody()

        <!-- Footer -->
        <footer class="w-full py-section-gap mt-section-gap border-t border-outline-variant/30 flex flex-col md:flex-row justify-between items-center gap-stack-md">
            <span class="font-label-md text-label-md font-bold text-on-surface">MediAI</span>
            <div class="flex flex-wrap justify-center gap-stack-md">
                <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary underline-offset-4 hover:underline transition-opacity" href="#">Privacy Policy</a>
                <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary underline-offset-4 hover:underline transition-opacity" href="#">Terms of Service</a>
                <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary underline-offset-4 hover:underline transition-opacity" href="#">HIPAA Compliance</a>
                <a class="font-label-sm text-label-sm text-on-surface-variant hover:text-primary underline-offset-4 hover:underline transition-opacity" href="#">Contact Support</a>
            </div>
            <p class="font-label-sm text-label-sm text-on-surface-variant">© 2026 MediAI Quantum Health. All rights reserved.</p>
        </footer>
    </main>

    <!-- Floating AI Chatbot -->
    <div class="fixed bottom-container-margin right-container-margin z-50 group">
        <div class="absolute bottom-[80px] right-0 w-[300px] glass-panel p-stack-md opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none mb-stack-sm origin-bottom-right scale-95 group-hover:scale-100">
            <p class="font-label-md text-label-md text-on-surface mb-1 font-bold">MediAI Assistant</p>
            <p class="font-body-md text-body-md text-on-surface-variant text-sm">Hello @(fullName.Split(' ')[0]), I am here to help you understand your reports or book an appointment.</p>
        </div>
        <button class="w-16 h-16 rounded-full bg-gradient-to-tr from-primary to-tertiary text-white shadow-[0_8px_32px_rgba(109,59,215,0.4)] flex items-center justify-center hover:scale-105 active:scale-95 transition-transform ai-glow" onclick="showComingSoon('AI Chatbot')">
            <span class="material-symbols-outlined text-[32px]">robot_2</span>
        </button>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        function showComingSoon(featureName) {
            toastr.info(`${featureName} is currently in development!`, "Coming Soon");
        }

        $(document).ready(function () {
            // Mobile menu toggle
            $('header button').on('click', function () {
                var sidebar = $('aside');
                sidebar.toggleClass('hidden flex');
                if (sidebar.hasClass('flex')) {
                    sidebar.css('z-index', '99999');
                }
            });
            
            // Hide sidebar on click outside for mobile
            $(document).click(function(event) { 
                var $target = $(event.target);
                if(!$target.closest('aside').length && !$target.closest('header button').length && $('aside').hasClass('flex')) {
                    $('aside').addClass('hidden').removeClass('flex');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
