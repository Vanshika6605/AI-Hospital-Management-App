@{ 
    Layout = "_PatientLayout"; 
    ViewData["Title"] = "Settings";
}

<div class="mb-section-gap">
    <h1 class="font-headline-lg text-headline-lg text-on-surface mb-stack-sm">Settings</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant">Manage your account preferences and security.</p>
</div>

<div class="glass-panel glass-glow p-container-margin max-w-4xl">
    <div class="space-y-section-gap">
        <!-- Account Settings -->
        <div>
            <h3 class="font-headline-md text-headline-md text-on-surface mb-stack-md border-b border-outline-variant/30 pb-2 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">manage_accounts</span>
                Account Security
            </h3>
            
            <div class="bg-surface-container-lowest p-4 rounded-xl border border-white/40 flex items-center justify-between mb-3">
                <div>
                    <h4 class="font-label-md text-label-md font-bold text-on-surface">Change Password</h4>
                    <p class="font-label-sm text-label-sm text-on-surface-variant">Update your password to keep your account secure.</p>
                </div>
                <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="bg-surface-container text-on-surface px-4 py-2 rounded-lg font-label-sm text-label-sm border border-outline-variant/50 hover:bg-surface-variant transition-colors">
                    Update
                </a>
            </div>
            
            <div class="bg-surface-container-lowest p-4 rounded-xl border border-white/40 flex items-center justify-between">
                <div>
                    <h4 class="font-label-md text-label-md font-bold text-on-surface">Two-Factor Authentication</h4>
                    <p class="font-label-sm text-label-sm text-on-surface-variant">Add an extra layer of security to your account.</p>
                </div>
                <a asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication" class="bg-surface-container text-on-surface px-4 py-2 rounded-lg font-label-sm text-label-sm border border-outline-variant/50 hover:bg-surface-variant transition-colors">
                    Configure
                </a>
            </div>
        </div>

        <!-- Notifications -->
        <div>
            <h3 class="font-headline-md text-headline-md text-on-surface mb-stack-md border-b border-outline-variant/30 pb-2 flex items-center gap-2">
                <span class="material-symbols-outlined text-tertiary">notifications</span>
                Notification Preferences
            </h3>
            
            <div class="space-y-3">
                <label class="flex items-center justify-between p-4 bg-surface-container-lowest rounded-xl border border-white/40 cursor-pointer">
                    <div>
                        <h4 class="font-label-md text-label-md font-bold text-on-surface">Appointment Reminders</h4>
                        <p class="font-label-sm text-label-sm text-on-surface-variant">Receive SMS and Email reminders before appointments.</p>
                    </div>
                    <input type="checkbox" checked class="form-checkbox h-5 w-5 text-primary rounded border-outline-variant/50 focus:ring-primary" />
                </label>
                
                <label class="flex items-center justify-between p-4 bg-surface-container-lowest rounded-xl border border-white/40 cursor-pointer">
                    <div>
                        <h4 class="font-label-md text-label-md font-bold text-on-surface">AI Health Alerts</h4>
                        <p class="font-label-sm text-label-sm text-on-surface-variant">Get notified when AI detects potential health anomalies.</p>
                    </div>
                    <input type="checkbox" checked class="form-checkbox h-5 w-5 text-primary rounded border-outline-variant/50 focus:ring-primary" />
                </label>
                
                <label class="flex items-center justify-between p-4 bg-surface-container-lowest rounded-xl border border-white/40 cursor-pointer">
                    <div>
                        <h4 class="font-label-md text-label-md font-bold text-on-surface">Billing Updates</h4>
                        <p class="font-label-sm text-label-sm text-on-surface-variant">Receive alerts when new invoices are generated.</p>
                    </div>
                    <input type="checkbox" checked class="form-checkbox h-5 w-5 text-primary rounded border-outline-variant/50 focus:ring-primary" />
                </label>
            </div>
        </div>
    </div>
</div>
