@{
    ViewData["Title"] = "Admin Dashboard";
}

@using AIHospitalManagementSys.Models.Enums

<div class="max-w-7xl mx-auto flex flex-col gap-section-gap pt-8 md:pt-0">
    <!-- Header Section -->
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-stack-md">
        <div>
            <p class="font-label-md text-label-md text-on-surface-variant mb-1">@DateTime.Today.ToString("dddd, MMMM dd")</p>
            <h2 class="font-display-lg text-display-lg text-on-surface">System <span class="gradient-text">Overview</span></h2>
        </div>
        <div class="flex gap-2">
            <a asp-controller="Doctor" asp-action="Create" class="bg-primary text-on-primary font-label-md text-label-md px-4 py-2 rounded-xl shadow-sm hover:opacity-90 transition-opacity flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">person_add</span>
                Add Doctor
            </a>
            <a asp-controller="Patient" asp-action="Create" class="bg-secondary text-on-secondary font-label-md text-label-md px-4 py-2 rounded-xl shadow-sm hover:opacity-90 transition-opacity flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">group_add</span>
                New Patient
            </a>
        </div>
    </header>

    <!-- Dashboard Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
        
        <!-- Key Metrics (Spans 3 cols each) -->
        <div class="col-span-1 md:col-span-3 glass-panel rounded-xl p-6 flex flex-col justify-center">
            <div class="flex justify-between items-start mb-2">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined">stethoscope</span>
                </div>
                <a asp-controller="Doctor" asp-action="Index" class="text-primary hover:bg-primary/10 rounded-full p-1 transition-colors">
                    <span class="material-symbols-outlined">arrow_outward</span>
                </a>
            </div>
            <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Total Doctors</h3>
            <span class="font-display-lg text-display-lg font-bold text-on-surface mt-1">@ViewBag.TotalDoctors</span>
        </div>

        <div class="col-span-1 md:col-span-3 glass-panel rounded-xl p-6 flex flex-col justify-center">
            <div class="flex justify-between items-start mb-2">
                <div class="w-10 h-10 rounded-full bg-secondary/10 flex items-center justify-center text-secondary">
                    <span class="material-symbols-outlined">groups</span>
                </div>
                <a asp-controller="Patient" asp-action="Index" class="text-secondary hover:bg-secondary/10 rounded-full p-1 transition-colors">
                    <span class="material-symbols-outlined">arrow_outward</span>
                </a>
            </div>
            <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Total Patients</h3>
            <span class="font-display-lg text-display-lg font-bold text-on-surface mt-1">@ViewBag.TotalPatients</span>
        </div>

        <div class="col-span-1 md:col-span-3 glass-panel rounded-xl p-6 flex flex-col justify-center">
            <div class="flex justify-between items-start mb-2">
                <div class="w-10 h-10 rounded-full bg-tertiary/10 flex items-center justify-center text-tertiary">
                    <span class="material-symbols-outlined">event</span>
                </div>
                <a asp-controller="Appointment" asp-action="Index" class="text-tertiary hover:bg-tertiary/10 rounded-full p-1 transition-colors">
                    <span class="material-symbols-outlined">arrow_outward</span>
                </a>
            </div>
            <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Appointments</h3>
            <span class="font-display-lg text-display-lg font-bold text-on-surface mt-1">@ViewBag.TotalAppointments</span>
        </div>

        <div class="col-span-1 md:col-span-3 glass-panel rounded-xl p-6 flex flex-col justify-center">
            <div class="flex justify-between items-start mb-2">
                <div class="w-10 h-10 rounded-full bg-error/10 flex items-center justify-center text-error">
                    <span class="material-symbols-outlined">domain</span>
                </div>
                <a asp-controller="Department" asp-action="Index" class="text-error hover:bg-error/10 rounded-full p-1 transition-colors">
                    <span class="material-symbols-outlined">arrow_outward</span>
                </a>
            </div>
            <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Departments</h3>
            <span class="font-display-lg text-display-lg font-bold text-on-surface mt-1">@ViewBag.TotalDepartments</span>
        </div>

        <!-- Appointment Trends Chart (Spans 8 cols) -->
        <div class="col-span-1 md:col-span-8 glass-panel rounded-xl p-6 flex flex-col h-[400px]">
            <h3 class="font-headline-md text-headline-md text-on-surface mb-6">Appointment Trends</h3>
            <div class="flex-1 w-full relative">
                <canvas id="myAreaChart"></canvas>
            </div>
        </div>

        <!-- Quick Actions (Spans 4 cols) -->
        <div class="col-span-1 md:col-span-4 glass-panel rounded-xl p-6 flex flex-col bg-gradient-to-br from-surface to-surface-container border border-outline-variant/30 relative overflow-hidden group">
            <div class="flex items-center gap-2 mb-6 relative z-10">
                <span class="material-symbols-outlined text-primary">bolt</span>
                <h3 class="font-headline-md text-headline-md text-on-surface">Quick Actions</h3>
            </div>
            
            <div class="flex flex-col gap-3 relative z-10">
                <a asp-controller="Appointment" asp-action="Book" class="flex items-center gap-3 p-3 rounded-lg bg-surface-container-lowest/80 border border-outline-variant/20 hover:bg-surface-container-lowest transition-colors group/item">
                    <span class="material-symbols-outlined text-secondary bg-secondary/10 p-2 rounded-lg group-hover/item:scale-110 transition-transform">calendar_add_on</span>
                    <span class="font-label-md text-label-md text-on-surface">Book Appointment</span>
                </a>
                
                <a href="javascript:void(0)" onclick="showComingSoon('Generate Report')" class="flex items-center gap-3 p-3 rounded-lg bg-surface-container-lowest/80 border border-outline-variant/20 hover:bg-surface-container-lowest transition-colors group/item">
                    <span class="material-symbols-outlined text-tertiary bg-tertiary/10 p-2 rounded-lg group-hover/item:scale-110 transition-transform">summarize</span>
                    <span class="font-label-md text-label-md text-on-surface">Generate Report</span>
                </a>
                
                <a asp-controller="Department" asp-action="Index" class="flex items-center gap-3 p-3 rounded-lg bg-surface-container-lowest/80 border border-outline-variant/20 hover:bg-surface-container-lowest transition-colors group/item">
                    <span class="material-symbols-outlined text-primary bg-primary/10 p-2 rounded-lg group-hover/item:scale-110 transition-transform">account_tree</span>
                    <span class="font-label-md text-label-md text-on-surface">Manage Departments</span>
                </a>
            </div>
        </div>

        <!-- Recent Appointments Table - Spans 12 cols -->
        <div class="col-span-1 md:col-span-12 glass-panel rounded-xl p-6 flex flex-col mt-4">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-headline-md text-headline-md text-on-surface">Recent Appointments</h3>
                <a asp-controller="Appointment" asp-action="Index" class="font-label-md text-label-md text-primary flex items-center gap-1 hover:underline">
                    View All <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
            </div>

            <div class="flex flex-col overflow-x-auto">
                <div class="min-w-[800px]">
                    <!-- Header -->
                    <div class="grid grid-cols-12 gap-4 px-4 py-3 bg-surface-container/50 rounded-t-xl border-b border-outline-variant/30 font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">
                        <div class="col-span-3">Patient</div>
                        <div class="col-span-4">Doctor</div>
                        <div class="col-span-3">Date</div>
                        <div class="col-span-2 text-right">Status</div>
                    </div>

                    @if (ViewBag.RecentAppointments != null)
                    {
                        var recent = (IEnumerable<dynamic>)ViewBag.RecentAppointments;
                        if (!recent.Any())
                        {
                            <div class="py-12 text-center border-b border-outline-variant/10">
                                <p class="font-body-md text-body-md text-on-surface-variant">No recent appointments found.</p>
                            </div>
                        }
                        foreach (var item in recent)
                        {
                            var statusClass = "";
                            var statusText = item.Status.ToString();
                            
                            switch ((AppointmentStatus)item.Status)
                            {
                                case AppointmentStatus.Pending: statusClass = "badge-pending"; break;
                                case AppointmentStatus.Confirmed: statusClass = "badge-confirmed"; break;
                                case AppointmentStatus.Completed: statusClass = "badge-completed"; break;
                                case AppointmentStatus.Cancelled: statusClass = "badge-cancelled"; break;
                            }

                            <div class="grid grid-cols-12 gap-4 px-4 py-4 border-b border-outline-variant/10 items-center hover:bg-surface-container-lowest/50 transition-colors">
                                <div class="col-span-3 font-label-md text-label-md text-on-surface font-bold">@item.PatientName</div>
                                <div class="col-span-4 font-body-md text-body-md text-on-surface-variant flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[18px] text-primary">stethoscope</span>
                                    Dr. @item.DoctorName
                                </div>
                                <div class="col-span-3 font-body-md text-body-md text-on-surface-variant">@item.AppointmentDate.ToString("MMM dd, yyyy - hh:mm tt")</div>
                                <div class="col-span-2 flex justify-end">
                                    <span class="badge @statusClass px-3 py-1 rounded-full font-label-sm text-label-sm">
                                        @statusText
                                    </span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="h-8"></div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Set default Chart.js fonts to match our design system
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.color = '#6e7881';

        // Area Chart
        var ctx = document.getElementById("myAreaChart");
        if (ctx) {
            var myLineChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(ViewBag.MonthlyAppointmentLabels ?? "[]"),
                    datasets: [{
                        label: "Appointments",
                        lineTension: 0.4, // Smooth curves
                        backgroundColor: "rgba(0, 101, 145, 0.1)", // Primary color with opacity
                        borderColor: "#006591",
                        pointRadius: 4,
                        pointBackgroundColor: "#ffffff",
                        pointBorderColor: "#006591",
                        pointHoverRadius: 6,
                        pointHoverBackgroundColor: "#006591",
                        pointHoverBorderColor: "#ffffff",
                        pointHitRadius: 10,
                        pointBorderWidth: 2,
                        fill: true,
                        data: @Html.Raw(ViewBag.MonthlyAppointmentData ?? "[]"),
                    }],
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(25, 28, 30, 0.9)',
                            titleFont: { size: 13, family: 'Inter' },
                            bodyFont: { size: 14, family: 'Inter', weight: 'bold' },
                            padding: 12,
                            displayColors: false,
                            callbacks: {
                                label: function(context) {
                                    return context.parsed.y + ' Appointments';
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false, drawBorder: false }
                        },
                        y: { 
                            beginAtZero: true,
                            grid: { 
                                color: 'rgba(110, 120, 129, 0.1)',
                                drawBorder: false,
                                borderDash: [5, 5]
                            },
                            ticks: {
                                maxTicksLimit: 5,
                                padding: 10
                            }
                        }
                    }
                }
            });
        }
    </script>
}
