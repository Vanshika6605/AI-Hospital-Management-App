@model AIHospitalManagementSys.ViewModels.DoctorViewModel

@{
    ViewData["Title"] = "Doctor Details";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-body text-center">
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                        {
                            <img src="@Model.ProfileImagePath" class="rounded-circle img-thumbnail shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Profile">
                        }
                        else
                        {
                            <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 150px; height: 150px;">
                                <i class="fas fa-user-md fa-5x text-secondary"></i>
                            </div>
                        }
                    </div>
                    <h4 class="fw-bold">@Model.FullName</h4>
                    <p class="text-primary fs-5 mb-1">@Model.Specialization</p>
                    <p class="text-muted"><i class="fas fa-hospital me-1"></i> @Model.DepartmentName</p>
                    
                    <div class="mt-3">
                        @if (Model.AvailabilityStatus)
                        {
                            <span class="badge bg-success px-3 py-2">Available for Appointments</span>
                        }
                        else
                        {
                            <span class="badge bg-danger px-3 py-2">Currently Unavailable</span>
                        }
                    </div>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-envelope me-2 text-muted"></i> Email</span>
                        <span class="text-primary">@Model.Email</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-phone me-2 text-muted"></i> Phone</span>
                        <span>@(Model.PhoneNumber ?? "N/A")</span>
                    </li>
                </ul>
                <div class="card-footer bg-transparent border-top-0 pt-0 text-center pb-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-info text-white w-100">Edit Profile</a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Professional Profile</h6>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Qualifications</div>
                        <div class="col-sm-8 text-dark">@Model.Qualifications</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Experience</div>
                        <div class="col-sm-8 text-dark">@Model.ExperienceYears Years</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Consultation Fees</div>
                        <div class="col-sm-8 text-dark text-success fw-bold">@Model.ConsultationFees.ToString("C")</div>
                    </div>
                    <hr />
                    <h6 class="text-primary mb-3">Biography & Expertise</h6>
                    <p class="text-dark">
                        @Model.FullName is a highly qualified @Model.Specialization within the @Model.DepartmentName department. 
                        With @Model.ExperienceYears years of dedicated experience, they provide expert consultation and care.
                    </p>
                </div>
            </div>

            <!-- Future: Appointment History / Schedule -->
            <div class="card shadow">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">Upcoming Appointments</h6>
                    <span class="badge bg-info">Coming Soon</span>
                </div>
                <div class="card-body">
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-calendar-alt fa-3x mb-3 opacity-25"></i>
                        <p>Appointment tracking will be available in the next phase.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left me-2"></i> Back to Doctor List</a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}
