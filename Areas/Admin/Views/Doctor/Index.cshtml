@model IEnumerable<AIHospitalManagementSys.ViewModels.DoctorViewModel>

@{
    ViewData["Title"] = "Manage Doctors";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Doctors</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-user-plus me-2"></i> Add New Doctor</a>
    </div>

    <!-- Search and Filter -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="search" class="form-control" placeholder="Search by name or specialization..." value="@ViewBag.Search">
                </div>
                <div class="col-md-3">
                    <select name="departmentId" class="form-select" asp-items="ViewBag.Departments">
                        <option value="">All Departments</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-info text-white w-100">Filter</button>
                </div>
                <div class="col-md-1">
                    <a asp-action="Index" class="btn btn-secondary w-100">Reset</a>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            @if (!string.IsNullOrEmpty(item.ProfileImagePath))
                            {
                                <img src="@item.ProfileImagePath" class="rounded-circle img-thumbnail" style="width: 100px; height: 100px; object-fit: cover;" alt="Profile">
                            }
                            else
                            {
                                <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                    <i class="fas fa-user-md fa-3x text-secondary"></i>
                                </div>
                            }
                        </div>
                        <div class="text-center">
                            <h5 class="fw-bold mb-1">@item.FullName</h5>
                            <p class="text-primary small mb-2">@item.Specialization</p>
                            <p class="text-muted small mb-0"><i class="fas fa-hospital me-1"></i> @item.DepartmentName</p>
                            <div class="mt-2">
                                @if (item.AvailabilityStatus)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Away</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 text-center pb-3">
                        <div class="btn-group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Edit</a>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete(@item.Id, '@item.FullName')">Delete</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Delete form used by SweetAlert -->
<form id="deleteForm" method="post" asp-action="Delete" style="display:none;">
    <input type="hidden" name="id" id="doctorId" />
</form>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Confirm Delete',
                html: `Are you sure you want to delete doctor <b>${name}</b>?<br/><small class="text-danger">This will also delete their login account.</small>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ba1a1a',
                cancelButtonColor: '#6e7881',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('doctorId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            });
        }
    </script>
}
