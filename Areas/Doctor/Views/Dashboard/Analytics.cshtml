@{ 
    Layout = "_DoctorLayout"; 
    ViewData["Title"] = "Analytics";
}

<div class="mb-section-gap">
    <h1 class="font-headline-lg text-headline-lg text-on-surface mb-stack-sm">Practice Analytics</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant">Monitor your consultation metrics and ward statistics.</p>
</div>

<div class="glass-panel glass-glow p-container-margin mb-section-gap">
    <div class="flex justify-between items-center mb-stack-md">
        <h3 class="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">bar_chart</span>
            Patient Volume (Last 6 Months)
        </h3>
        <select class="bg-surface-bright border border-outline-variant/50 rounded-lg p-1 text-sm font-label-sm">
            <option>Last 6 Months</option>
            <option>This Year</option>
        </select>
    </div>
    
    <!-- Placeholder for Chart.js -->
    <div class="w-full h-64 bg-surface-container-low rounded-xl flex items-center justify-center border border-outline-variant/30">
        <div class="text-center">
            <span class="material-symbols-outlined text-6xl text-primary/30 mb-2">analytics</span>
            <p class="font-label-md text-label-md text-on-surface-variant">Interactive Volume Chart Loading...</p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
    <div class="glass-panel glass-glow p-container-margin text-center">
        <h3 class="font-label-md text-label-md text-on-surface-variant mb-2">Average Consultation Time</h3>
        <p class="font-display-lg text-display-lg text-primary font-bold">14<span class="text-xl">m</span></p>
        <p class="font-label-sm text-secondary flex items-center justify-center gap-1 mt-2">
            <span class="material-symbols-outlined text-[14px]">trending_down</span> 2m vs last month
        </p>
    </div>

    <div class="glass-panel glass-glow p-container-margin text-center">
        <h3 class="font-label-md text-label-md text-on-surface-variant mb-2">Total Patients</h3>
        <p class="font-display-lg text-display-lg text-tertiary font-bold">1,248</p>
        <p class="font-label-sm text-secondary flex items-center justify-center gap-1 mt-2">
            <span class="material-symbols-outlined text-[14px]">trending_up</span> +12% vs last month
        </p>
    </div>

    <div class="glass-panel glass-glow p-container-margin text-center">
        <h3 class="font-label-md text-label-md text-on-surface-variant mb-2">Patient Satisfaction</h3>
        <p class="font-display-lg text-display-lg text-secondary font-bold">4.8<span class="text-xl">/5</span></p>
        <div class="flex justify-center text-secondary mt-2 text-sm">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star_half</span>
        </div>
    </div>
</div>
