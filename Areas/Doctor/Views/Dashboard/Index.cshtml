@model AIHospitalManagementSys.ViewModels.DoctorViewModel
@{ 
    Layout = "_DoctorLayout"; 
    ViewData["Title"] = "Dashboard";
}

<!-- Emergency Alert Banner (Floating) -->
<div class="absolute top-container-margin right-container-margin z-50 glass-panel border-error/50 bg-error-container/80 rounded-xl p-4 shadow-[0_4px_20px_rgba(186,26,26,0.15)] flex items-start gap-3 w-80 animate-pulse">
    <span class="material-symbols-outlined text-error mt-0.5">warning</span>
    <div>
        <h4 class="font-label-md text-label-md text-on-error-container">Code Blue Alert</h4>
        <p class="font-label-sm text-label-sm text-on-error-container/80 mt-1">ICU Bed 4 - Immediate attention required. Patient vitals dropping rapidly.</p>
    </div>
    <button class="text-on-error-container hover:bg-error/10 rounded-full p-1 transition-colors ml-auto" onclick="this.parentElement.style.display='none'">
        <span class="material-symbols-outlined">close</span>
    </button>
</div>

<div class="max-w-7xl mx-auto flex flex-col gap-section-gap pt-8 md:pt-0">
    <!-- Header Section -->
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-stack-md">
        <div>
            <p class="font-label-md text-label-md text-on-surface-variant mb-1">@DateTime.Today.ToString("dddd, MMMM dd")</p>
            <h2 class="font-display-lg text-display-lg text-on-surface">Good Morning, <span class="gradient-text">@Model.FullName</span></h2>
        </div>
    </header>

    <!-- Dashboard Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
        
        <!-- Summary Cards (Spans 12 cols, 3 items) -->
        <div class="col-span-1 md:col-span-4 glass-panel rounded-xl p-6 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined">event</span>
                </div>
                <h3 class="font-headline-md text-headline-md text-on-surface">Appointments</h3>
            </div>
            <div class="flex items-baseline gap-2 mt-2">
                <span class="font-display-lg text-display-lg font-bold text-on-surface">@(ViewBag.UpcomingAppointments != null ? ((IEnumerable<AIHospitalManagementSys.ViewModels.AppointmentViewModel>)ViewBag.UpcomingAppointments).Count() : 0)</span>
                <span class="font-label-md text-label-md text-on-surface-variant">Scheduled for today</span>
            </div>
        </div>

        <div class="col-span-1 md:col-span-4 glass-panel rounded-xl p-6 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-full bg-secondary/10 flex items-center justify-center text-secondary">
                    <span class="material-symbols-outlined">groups</span>
                </div>
                <h3 class="font-headline-md text-headline-md text-on-surface">Consultations</h3>
            </div>
            <div class="flex items-baseline gap-2 mt-2">
                <span class="font-display-lg text-display-lg font-bold text-on-surface">@(ViewBag.TotalAppointments ?? 0)</span>
                <span class="font-label-md text-label-md text-on-surface-variant">Under your care</span>
            </div>
        </div>

        <div class="col-span-1 md:col-span-4 glass-panel rounded-xl p-6 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-full bg-tertiary/10 flex items-center justify-center text-tertiary">
                    <span class="material-symbols-outlined">psychology</span>
                </div>
                <h3 class="font-headline-md text-headline-md text-on-surface">AI Diagnostics</h3>
            </div>
            <p class="font-body-md text-body-md text-on-surface-variant mt-2">
                Advanced predictive modeling will activate as more clinical data is gathered.
            </p>
        </div>

        <!-- Appointment Summary - Spans 12 cols -->
        <div class="col-span-1 md:col-span-12 glass-panel rounded-xl p-6 flex flex-col ai-glow mt-4">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-headline-md text-headline-md text-on-surface">Upcoming Appointments</h3>
                <a asp-action="Schedules" class="font-label-md text-label-md text-primary flex items-center gap-1 hover:underline">
                    View All <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </a>
            </div>

            <!-- Table rows -->
            <div class="flex flex-col">
                <!-- Header -->
                <div class="grid grid-cols-12 gap-4 px-4 py-2 border-b border-outline-variant/30 font-label-sm text-label-sm text-on-surface-variant">
                    <div class="col-span-4">Patient</div>
                    <div class="col-span-3">Time</div>
                    <div class="col-span-3">Reason</div>
                    <div class="col-span-2 text-right">Status</div>
                </div>

                @if (ViewBag.UpcomingAppointments != null)
                {
                    var upcoming = (IEnumerable<AIHospitalManagementSys.ViewModels.AppointmentViewModel>)ViewBag.UpcomingAppointments;
                    if (!upcoming.Any())
                    {
                        <div class="py-12 text-center">
                            <span class="material-symbols-outlined text-4xl text-outline-variant mb-2">event_busy</span>
                            <p class="font-body-md text-body-md text-on-surface-variant">No appointments scheduled for today.</p>
                        </div>
                    }
                    foreach (var apt in upcoming)
                    {
                        var patientName = apt.PatientName ?? "Unknown";
                        var patientInitials = string.Join("", patientName.Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : "")).ToUpper();
                        if (patientInitials.Length > 2) patientInitials = patientInitials.Substring(0, 2);

                        var statusClass = apt.Status == AIHospitalManagementSys.Models.Enums.AppointmentStatus.Completed ? "badge-completed" : 
                                         (apt.Status == AIHospitalManagementSys.Models.Enums.AppointmentStatus.Pending ? "badge-pending" : "badge-confirmed");

                        <div class="grid grid-cols-12 gap-4 px-4 py-4 border-b border-outline-variant/10 items-center hover:bg-surface-container-lowest/50 transition-colors">
                            <div class="col-span-4 flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-primary-fixed text-on-primary-fixed flex items-center justify-center font-label-sm font-bold">@patientInitials</div>
                                <div>
                                    <p class="font-label-md text-label-md text-on-surface">@patientName</p>
                                    <p class="font-label-sm text-label-sm text-on-surface-variant">ID: #@apt.PatientId</p>
                                </div>
                            </div>
                            <div class="col-span-3 font-body-md text-body-md text-on-surface-variant">@apt.AppointmentDate.ToString("hh:mm tt")</div>
                            <div class="col-span-3 font-body-md text-body-md text-on-surface-variant truncate" title="@apt.Reason">@apt.Reason</div>
                            <div class="col-span-2 flex justify-end">
                                <span class="badge @statusClass px-3 py-1 rounded-full font-label-sm text-label-sm flex items-center gap-1">
                                    @apt.Status
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="py-12 text-center">
                        <span class="material-symbols-outlined text-4xl text-outline-variant mb-2">event_busy</span>
                        <p class="font-body-md text-body-md text-on-surface-variant">No appointments found.</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="h-8"></div> <!-- Bottom padding -->
</div>
