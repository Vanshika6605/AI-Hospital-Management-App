@using AIHospitalManagementSys.Models.Enums
@model AIHospitalManagementSys.ViewModels.DoctorViewModel

@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold">Welcome, Dr. @Model.FullName</h2>
            <p class="text-muted">You have @(((IEnumerable<AIHospitalManagementSys.ViewModels.AppointmentViewModel>)ViewBag.TodayAppointments).Count()) appointments scheduled for today.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <div class="badge bg-primary fs-6 px-3 py-2">@DateTime.Now.ToString("dddd, MMM dd, yyyy")</div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-white p-3 h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-light-primary p-3 me-3">
                        <i class="fas fa-calendar-check fa-2x text-primary"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Patients</div>
                        <div class="h4 fw-bold mb-0">@ViewBag.TotalAppointments</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-white p-3 h-100">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-light-success p-3 me-3">
                        <i class="fas fa-check-double fa-2x text-success"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Completed</div>
                        <div class="h4 fw-bold mb-0">@ViewBag.CompletedAppointments</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Today's Appointments</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Time</th>
                                    <th>Patient</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ViewBag.TodayAppointments)
                                {
                                    <tr>
                                        <td class="fw-bold">@item.AppointmentDate.ToString("hh:mm tt")</td>
                                        <td>@item.PatientName</td>
                                        <td>
                                            @if (item.Status == AppointmentStatus.Confirmed)
                                            {
                                                <span class="badge bg-success">Confirmed</span>
                                            }
                                            else if (item.Status == AppointmentStatus.Pending)
                                            {
                                                <span class="badge bg-warning text-dark">Pending</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@item.Status</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.Status != AppointmentStatus.Completed && item.Status != AppointmentStatus.Cancelled)
                                            {
                                                <a asp-controller="Prescription" asp-action="Create" asp-route-appointmentId="@item.Id" class="btn btn-sm btn-primary">
                                                    Check Patient
                                                </a>
                                            }
                                            else if (item.Status == AppointmentStatus.Completed)
                                            {
                                                <span class="text-success small"><i class="fas fa-check me-1"></i> Finished</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!((IEnumerable<AIHospitalManagementSys.ViewModels.AppointmentViewModel>)ViewBag.TodayAppointments).Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No appointments for today.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <span><i class="fas fa-clock me-2 text-info"></i> Manage Schedule</span>
                                <i class="fas fa-chevron-right small text-muted"></i>
                            </div>
                        </a>
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <span><i class="fas fa-user-edit me-2 text-success"></i> Edit My Profile</span>
                                <i class="fas fa-chevron-right small text-muted"></i>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        .bg-light-primary { background-color: rgba(78, 115, 223, 0.1); }
        .bg-light-success { background-color: rgba(28, 200, 138, 0.1); }
    </style>
}
