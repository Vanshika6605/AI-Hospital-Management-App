@model IEnumerable<AIHospitalManagementSys.ViewModels.AppointmentViewModel>
@{ 
    Layout = "_DoctorLayout"; 
    ViewData["Title"] = "My Patients";
}

<div class="mb-section-gap">
    <h1 class="font-headline-lg text-headline-lg text-on-surface mb-stack-sm">My Patients</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant">Manage and review your patient records.</p>
</div>

<div class="glass-panel glass-glow p-container-margin">
    
    <div class="flex justify-between items-center mb-section-gap border-b border-outline-variant/30 pb-4">
        <h2 class="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">groups</span>
            Patient Roster
        </h2>
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 transform -translate-y-1/2 text-on-surface-variant">search</span>
            <input type="text" placeholder="Search patients..." class="pl-10 pr-4 py-2 rounded-xl border border-outline-variant/50 bg-surface focus:ring-1 focus:ring-primary focus:border-primary outline-none font-body-md" />
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-12">
            <span class="material-symbols-outlined text-6xl text-on-surface-variant/50 mb-4">group_off</span>
            <h3 class="font-headline-md text-headline-md text-on-surface mb-2">No Patients Found</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">You don't have any associated patients yet.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-gutter">
            @foreach (var apt in Model.GroupBy(a => a.PatientId).Select(g => g.First()))
            {
                <div class="bg-surface-bright rounded-2xl border border-outline-variant/30 p-stack-md flex flex-col transition-transform hover:scale-[1.02] shadow-sm">
                    <div class="flex justify-between items-start mb-stack-md border-b border-outline-variant/30 pb-3">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-headline-md">
                                @(string.IsNullOrEmpty(apt.PatientName) ? "?" : apt.PatientName[0].ToString().ToUpper())
                            </div>
                            <div>
                                <h3 class="font-headline-md text-headline-md text-on-surface">@apt.PatientName</h3>
                                <p class="font-label-sm text-label-sm text-on-surface-variant">ID: #@apt.PatientId</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="flex-1 mb-stack-md">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-[18px] text-tertiary">history</span>
                            <span class="font-label-sm text-label-sm text-on-surface-variant">Last Visit: @apt.AppointmentDate.ToString("MMM dd, yyyy")</span>
                        </div>
                        <p class="font-label-sm text-label-sm text-on-surface-variant mb-1 uppercase tracking-wider font-bold">Recent Reason</p>
                        <p class="font-body-md text-body-md text-on-surface truncate">@apt.Reason</p>
                    </div>

                    <div class="mt-auto">
                        <button class="w-full bg-surface-container-high text-on-surface px-4 py-2 rounded-xl font-label-md text-label-md hover:bg-primary hover:text-on-primary transition-colors flex items-center justify-center gap-2" onclick="showComingSoon('View Full History')">
                            <span class="material-symbols-outlined text-[20px]">medical_information</span>
                            View Full History
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>
