@model AIHospitalManagementSys.ViewModels.PrescriptionViewModel
@{
    Layout = "_DoctorLayout";
    ViewData["Title"] = "Prescription Details";
}

<div class="max-w-4xl mx-auto flex flex-col gap-section-gap pt-8 md:pt-0 pb-12">
    <!-- Header -->
    <header class="flex flex-col md:flex-row md:items-center justify-between gap-stack-md no-print">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <a href="javascript:history.back()" class="text-on-surface-variant hover:text-primary transition-colors flex items-center">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    <span class="font-label-md ml-1">Back</span>
                </a>
            </div>
            <h2 class="font-display-lg text-display-lg text-on-surface">Prescription <span class="gradient-text">Details</span></h2>
        </div>
        <div class="flex gap-2">
            <button class="bg-surface-container-high text-on-surface font-label-md text-label-md px-4 py-2 rounded-xl shadow-sm hover:opacity-90 transition-opacity flex items-center gap-2" onclick="window.print()">
                <span class="material-symbols-outlined text-[18px]">print</span>
                Print
            </button>
            <!-- Workflow transition to billing happens automatically in backend, but we show a button if applicable -->
            <button class="bg-primary text-on-primary font-label-md text-label-md px-4 py-2 rounded-xl shadow-sm hover:opacity-90 transition-opacity flex items-center gap-2" onclick="showComingSoon('Generate Bill')">
                <span class="material-symbols-outlined text-[18px]">receipt_long</span>
                Generate Bill
            </button>
        </div>
    </header>

    <!-- Visual Workflow Timeline -->
    <div class="glass-panel p-6 no-print">
        <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-6 text-center">Clinical Workflow Status</h3>
        
        <div class="relative flex justify-between items-center max-w-2xl mx-auto">
            <!-- Connecting Line -->
            <div class="absolute left-[10%] right-[10%] top-1/2 -translate-y-1/2 h-1 bg-surface-container-high -z-10"></div>
            <div class="absolute left-[10%] w-[50%] top-1/2 -translate-y-1/2 h-1 bg-secondary -z-10"></div>

            <!-- Step 1 -->
            <div class="flex flex-col items-center gap-2 relative">
                <div class="w-10 h-10 rounded-full bg-secondary text-on-secondary flex items-center justify-center shadow-md">
                    <span class="material-symbols-outlined text-[20px]">calendar_check</span>
                </div>
                <span class="font-label-sm text-label-sm text-secondary font-bold">Appointment</span>
            </div>

            <!-- Step 2 -->
            <div class="flex flex-col items-center gap-2 relative">
                <div class="w-10 h-10 rounded-full bg-secondary text-on-secondary flex items-center justify-center shadow-md">
                    <span class="material-symbols-outlined text-[20px]">stethoscope</span>
                </div>
                <span class="font-label-sm text-label-sm text-secondary font-bold">Consultation</span>
            </div>

            <!-- Step 3 -->
            <div class="flex flex-col items-center gap-2 relative">
                <div class="w-10 h-10 rounded-full bg-secondary text-on-secondary flex items-center justify-center shadow-[0_0_15px_rgba(0,107,95,0.4)] ring-4 ring-secondary/20">
                    <span class="material-symbols-outlined text-[20px]">prescriptions</span>
                </div>
                <span class="font-label-sm text-label-sm text-secondary font-bold">Prescription</span>
            </div>

            <!-- Step 4 -->
            <div class="flex flex-col items-center gap-2 relative">
                <div class="w-10 h-10 rounded-full bg-surface-container-high text-on-surface-variant flex items-center justify-center border-2 border-surface-container-high">
                    <span class="material-symbols-outlined text-[20px]">payments</span>
                </div>
                <span class="font-label-sm text-label-sm text-on-surface-variant">Billing Pending</span>
            </div>
        </div>
    </div>

    <!-- Prescription Printable Document -->
    <div class="bg-white text-black p-8 md:p-12 shadow-xl border border-outline-variant/20 mx-auto w-full max-w-4xl" id="prescriptionDocument">
        <!-- Header -->
        <div class="flex justify-between items-start border-b-2 border-black pb-6 mb-6">
            <div class="flex items-center gap-3">
                <div class="w-16 h-16 bg-primary text-white flex items-center justify-center rounded-lg">
                    <span class="material-symbols-outlined text-4xl">health_and_safety</span>
                </div>
                <div>
                    <h1 class="text-3xl font-black text-primary tracking-tight m-0">MediAI Health</h1>
                    <p class="text-sm text-gray-500 m-0">Advanced Clinical Care</p>
                </div>
            </div>
            <div class="text-right">
                <h2 class="text-xl font-bold text-gray-800 m-0">Dr. @Model.DoctorName</h2>
                <p class="text-sm text-gray-600 m-0">Consultant Physician</p>
                <p class="text-xs text-gray-500 mt-1">Date: @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
            </div>
        </div>

        <!-- Patient Info -->
        <div class="bg-gray-50 rounded-lg p-4 mb-8 grid grid-cols-2 gap-4 border border-gray-200">
            <div>
                <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Patient Name</p>
                <p class="font-bold text-lg m-0">@Model.PatientName</p>
            </div>
            <div class="text-right">
                <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Prescription ID</p>
                <p class="font-mono font-bold text-gray-700 m-0">PR-@Model.Id.ToString("D5")</p>
            </div>
        </div>

        <!-- Diagnosis & Notes -->
        <div class="mb-8">
            <h3 class="flex items-center gap-2 text-lg font-bold text-gray-800 border-b border-gray-200 pb-2 mb-4">
                <span class="material-symbols-outlined text-primary">clinical_notes</span> Clinical Notes
            </h3>
            <p class="text-gray-700 whitespace-pre-wrap pl-2 border-l-4 border-primary/20">@Model.Notes</p>
        </div>

        <!-- Rx icon -->
        <div class="text-4xl font-serif text-primary font-bold mb-4 italic">Rx</div>

        <!-- Medicines Table -->
        <div class="w-full mb-16">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-100 text-gray-700 text-sm uppercase tracking-wider">
                        <th class="p-3 rounded-tl-lg font-bold">Medicine</th>
                        <th class="p-3 font-bold">Dosage</th>
                        <th class="p-3 font-bold">Frequency</th>
                        <th class="p-3 rounded-tr-lg font-bold">Qty</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="p-3 font-medium text-gray-900">@item.MedicineName</td>
                                <td class="p-3 text-gray-600">@item.Dosage</td>
                                <td class="p-3 text-gray-600">@item.Frequency</td>
                                <td class="p-3 text-gray-900 font-bold">@item.Quantity</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="p-6 text-center text-gray-500 italic">No medicines prescribed.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer / Signatures -->
        <div class="flex justify-between items-end pt-12 border-t-2 border-gray-200 mt-auto">
            <div class="text-xs text-gray-500 max-w-[50%]">
                <p class="mb-1"><strong>Notice:</strong> This prescription is valid only when stamped and signed by the authorized practitioner.</p>
                <p>Generated by MediAI Hospital Management System.</p>
            </div>
            <div class="text-center w-48">
                <div class="border-b border-black mb-2 pb-8"></div>
                <p class="text-sm font-bold text-gray-800 m-0">Dr. @Model.DoctorName</p>
                <p class="text-xs text-gray-500 m-0">Signature & Seal</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            body { 
                background: white !important; 
                margin: 0 !important; 
                padding: 0 !important;
            }
            .no-print { display: none !important; }
            #prescriptionDocument {
                box-shadow: none !important;
                border: none !important;
                width: 100% !important;
                max-width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
            }
            /* Hide the sidebar and top nav for printing */
            nav, header, aside { display: none !important; }
            main { margin-left: 0 !important; padding: 0 !important; }
        }
    </style>
}
